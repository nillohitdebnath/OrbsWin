<Window x:Class="OrbsWin.Tools.ClipboardHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clipboard History"
        Width="260" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border Style="{StaticResource ShadcnCard}" Margin="8">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header / Drag Bar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,8" MouseLeftButtonDown="OnHeaderDrag">
                <TextBlock Text="Clipboard History" Foreground="{StaticResource BrushTextPrimary}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Pin Button -->
                    <Button x:Name="PinButton" Click="OnPinClick" Foreground="{StaticResource BrushTextSecondary}" Background="Transparent" BorderThickness="0" FontSize="12" Margin="0,0,4,0" Cursor="Hand" ToolTip="Pin window (stay open)">
                        <TextBlock x:Name="PinIconText" Text="📌" Opacity="0.5"/>
                    </Button>
                    <!-- Close Button -->
                    <Button Content="✕" Click="OnCloseClick" Foreground="{StaticResource BrushTextSecondary}" Background="Transparent" BorderThickness="0" FontSize="12" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>

            <!-- History List -->
            <ListBox x:Name="HistoryListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="OnHistoryItemClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BrushBackground}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="{StaticResource RadiusControl}" Padding="8,6" Margin="0,2" HorizontalAlignment="Stretch">
                            <TextBlock Text="{Binding}" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" MaxHeight="36" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
