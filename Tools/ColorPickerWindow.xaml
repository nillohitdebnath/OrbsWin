<Window x:Class="OrbsWin.Tools.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ColorPickerWindow"
        Width="180" Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border Style="{StaticResource ShadcnCard}" Margin="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Color Swatch & Hex Display -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Border x:Name="ColorPreviewBox" Width="24" Height="24" CornerRadius="4" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Margin="0,0,8,0">
                    <Border.Background>
                        <SolidColorBrush x:Name="ColorPreviewBrush" Color="Black"/>
                    </Border.Background>
                </Border>
                <TextBlock x:Name="HexCodeText" Text="#000000" Foreground="{StaticResource BrushTextPrimary}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Magnified Pixel Grid View -->
            <Border Grid.Row="1" CornerRadius="{StaticResource RadiusControl}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" ClipToBounds="True" Background="Black">
                <Grid>
                    <Image x:Name="MagnifierImage" Stretch="Fill" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    <!-- Center Crosshair reticle -->
                    <Border Width="8" Height="8" BorderBrush="#FFFF00" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Toast / Guidance Text -->
            <TextBlock x:Name="ToastText" Grid.Row="2" Text="Click to Copy | Esc to Cancel" Foreground="{StaticResource BrushTextSecondary}" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
