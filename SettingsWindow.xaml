<Window x:Class="OrbsWin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrbsWin Settings"
        Width="650" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24"
        Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- General Settings -->
        <Border Grid.Row="0" Background="#2A2A32" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows automatically" Foreground="White" FontSize="13" FontWeight="SemiBold" Checked="OnStartWithWindowsChanged" Unchecked="OnStartWithWindowsChanged"/>
        </Border>

        <!-- Main Configuration Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree & Controls Column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TreeView x:Name="ItemsTreeView" Grid.Row="0" Background="#2A2A32" Foreground="White" BorderThickness="1" BorderBrush="#40FFFFFF" SelectedItemChanged="OnTreeSelectionChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                                <TextBlock Text=" (" Foreground="#A0FFFFFF" FontSize="11"/>
                                <TextBlock Text="{Binding ItemType}" Foreground="#8080FF" FontSize="11"/>
                                <TextBlock Text=")" Foreground="#A0FFFFFF" FontSize="11"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,8,0,0">
                    <Button Content="➕ Add" Click="OnAddItemClick" Margin="2" Padding="4" Background="#3A3A45" Foreground="White" BorderThickness="0"/>
                    <Button Content="🗑 Delete" Click="OnDeleteItemClick" Margin="2" Padding="4" Background="#3A3A45" Foreground="White" BorderThickness="0"/>
                    <Button Content="▲ Up" Click="OnMoveUpClick" Margin="2" Padding="4" Background="#3A3A45" Foreground="White" BorderThickness="0"/>
                    <Button Content="▼ Down" Click="OnMoveDownClick" Margin="2" Padding="4" Background="#3A3A45" Foreground="White" BorderThickness="0"/>
                </UniformGrid>
            </Grid>

            <!-- Detail Form Column -->
            <Border Grid.Column="2" Background="#2A2A32" CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailFormPanel" IsEnabled="False">
                        <TextBlock Text="Edit Item Details" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,16"/>

                        <!-- Name -->
                        <TextBlock Text="Name:" Foreground="#A0FFFFFF" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ItemNameTextBox" Background="#1E1E24" Foreground="White" BorderBrush="#60FFFFFF" Padding="6" Margin="0,0,0,12" TextChanged="OnFormFieldsChanged"/>

                        <!-- Type -->
                        <TextBlock Text="Action Type:" Foreground="#A0FFFFFF" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ItemTypeComboBox" Background="#1E1E24" Foreground="Black" Padding="6" Margin="0,0,0,12" SelectionChanged="OnItemTypeChanged">
                            <ComboBoxItem Content="builtin_tool"/>
                            <ComboBoxItem Content="app_launch"/>
                            <ComboBoxItem Content="shell_command"/>
                            <ComboBoxItem Content="snippet"/>
                            <ComboBoxItem Content="submenu"/>
                        </ComboBox>

                        <!-- Value / Command / Path -->
                        <TextBlock x:Name="ValueLabel" Text="Value / Target:" Foreground="#A0FFFFFF" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ItemValueTextBox" Background="#1E1E24" Foreground="White" BorderBrush="#60FFFFFF" Padding="6" Margin="0,0,0,12" TextChanged="OnFormFieldsChanged"/>

                        <!-- Submenu Action -->
                        <Button x:Name="AddSubitemButton" Content="+ Add Child Sub-Item" Click="OnAddSubitemClick" Margin="0,8,0,0" Padding="8" Background="#FF007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Save & Cancel Bar -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button Content="Save &amp; Apply" Click="OnSaveClick" Width="120" Padding="8" Background="#FF007ACC" Foreground="White" BorderThickness="0" FontWeight="Bold" HorizontalAlignment="Right" Cursor="Hand"/>
        </DockPanel>
    </Grid>
</Window>
