<Window x:Class="OrbsWin.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrbsWin Settings"
        Width="680" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushTextPrimary}"
        FontFamily="{StaticResource AppFontFamily}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- General Settings Header Card -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="{StaticResource RadiusCard}" Padding="12,10" Margin="0,0,0,12">
            <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows automatically" Checked="OnStartWithWindowsChanged" Unchecked="OnStartWithWindowsChanged"/>
        </Border>

        <!-- Main Configuration Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree & Toolbar Column -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="{StaticResource RadiusCard}" Padding="4">
                    <TreeView x:Name="ItemsTreeView" Background="Transparent" Foreground="{StaticResource BrushTextPrimary}" BorderThickness="0" SelectedItemChanged="OnTreeSelectionChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushTextPrimary}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" (" Foreground="{StaticResource BrushTextSecondary}" FontSize="11"/>
                                    <TextBlock Text="{Binding ItemType}" Foreground="{StaticResource BrushAccent}" FontSize="11"/>
                                    <TextBlock Text=")" Foreground="{StaticResource BrushTextSecondary}" FontSize="11"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,8,0,0">
                    <Button Content="Add" Click="OnAddItemClick" Margin="2" Padding="4"/>
                    <Button Content="Delete" Click="OnDeleteItemClick" Margin="2" Padding="4"/>
                    <Button Content="Up" Click="OnMoveUpClick" Margin="2" Padding="4"/>
                    <Button Content="Down" Click="OnMoveDownClick" Margin="2" Padding="4"/>
                </UniformGrid>
            </Grid>

            <!-- Detail Form Column -->
            <Border Grid.Column="2" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="{StaticResource RadiusCard}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailFormPanel" IsEnabled="False">
                        <TextBlock Text="Edit Item Details" FontSize="15" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,16"/>

                        <!-- Name -->
                        <TextBlock Text="Name:" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ItemNameTextBox" Margin="0,0,0,12" TextChanged="OnFormFieldsChanged"/>

                        <!-- Type -->
                        <TextBlock Text="Action Type:" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ItemTypeComboBox" Background="{StaticResource BrushBackground}" Foreground="{StaticResource BrushTextPrimary}" Padding="6" Margin="0,0,0,12" SelectionChanged="OnItemTypeChanged">
                            <ComboBoxItem Content="builtin_tool"/>
                            <ComboBoxItem Content="app_launch"/>
                            <ComboBoxItem Content="shell_command"/>
                            <ComboBoxItem Content="snippet"/>
                            <ComboBoxItem Content="submenu"/>
                        </ComboBox>

                        <!-- Value / Command / Path -->
                        <TextBlock x:Name="ValueLabel" Text="Value / Target:" Foreground="{StaticResource BrushTextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ItemValueTextBox" Margin="0,0,0,12" TextChanged="OnFormFieldsChanged"/>

                        <!-- Submenu Action -->
                        <Button x:Name="AddSubitemButton" Content="+ Add Child Sub-Item" Style="{StaticResource ShadcnPrimaryButton}" Click="OnAddSubitemClick" Margin="0,8,0,0" Padding="8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Save Footer Bar -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button Content="Save &amp; Apply" Style="{StaticResource ShadcnPrimaryButton}" Click="OnSaveClick" Width="130" Padding="8" HorizontalAlignment="Right" Cursor="Hand"/>
        </DockPanel>
    </Grid>
</Window>
